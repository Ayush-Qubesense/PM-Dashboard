# Copy this file to .env.local for local overrides (git-ignored).
#
# Local dev: leave VITE_API_BASE_URL unset — Vite's proxy forwards /api
# requests to localhost:8000 automatically (see vite.config.ts).
#
# Vercel production: set this to your Render service URL in the Vercel
# dashboard under Settings → Environment Variables.
VITE_API_BASE_URL=https://your-app-name.onrender.com/api